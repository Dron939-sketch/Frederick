# Database
DATABASE_URL=postgresql://fredi_user:password@localhost:5432/fredi_db

# Redis
REDIS_URL=redis://localhost:6379

# APIs
DEEPSEEK_API_KEY=sk-xxxxxxxxxxxxx
DEEPGRAM_API_KEY=xxxxxxxxxxxxx
YANDEX_API_KEY=xxxxxxxxxxxxx
OPENWEATHER_API_KEY=xxxxxxxxxxxxx

# App
ENVIRONMENT=production
LOG_LEVEL=info
DEBUG=false

# Performance
DB_POOL_MIN_SIZE=5
DB_POOL_MAX_SIZE=20
REDIS_MAX_CONNECTIONS=20
UVICORN_WORKERS=2
UVICORN_LIMIT_CONCURRENCY=100

# Timeouts
REQUEST_TIMEOUT=30
VOICE_TIMEOUT=60
DEEPSEEK_TIMEOUT=30

# Freddy SDK
FREDDY_URL=https://agent-ynlg.onrender.com
FREDDY_USERNAME=frederick_bot
FREDDY_PASSWORD=
FREDDY_TOKEN=

# Security
SECRET_KEY=your-secret-key-here
CORS_ORIGINS=https://fredi-frontend.onrender.com,http://localhost:3000

YOOKASSA_SHOP_ID=123456
YOOKASSA_SECRET_KEY=test_xxxxxxxxxxxxxxxxxxxxxxxxxxxxx
