# Не хранить в репозитории! Добавить в Render вручную
DATABASE_URL=postgresql://...
REDIS_URL=redis://...
DEEPSEEK_API_KEY=sk-...
DEEPGRAM_API_KEY=...
YANDEX_API_KEY=...
OPENWEATHER_API_KEY=...

# Конфигурация
ENVIRONMENT=production
LOG_LEVEL=info
DEBUG=false

# Производительность
DB_POOL_MIN_SIZE=5
DB_POOL_MAX_SIZE=20
REDIS_MAX_CONNECTIONS=20
UVICORN_WORKERS=2
UVICORN_LIMIT_CONCURRENCY=100

# Таймауты
REQUEST_TIMEOUT=30
VOICE_TIMEOUT=60
DEEPSEEK_TIMEOUT=30

# Безопасность
SECRET_KEY=generate-random-secret
CORS_ORIGINS=https://fredi-frontend.onrender.com
